=\"scope\">\r\n          <!-- 1. 如果有图片，循环展示所有图片 -->\r\n          <template v-if=\"scope.row.imagesList?.length > 0\">\r\n            <img\r\n                v-for=\"(img, index) in scope.row.imagesList\"\r\n                :key=\"'img-' + index\"\r\n                :src=\"img\"\r\n                style=\"max-width: 50px; max-height: 100px; margin-right: 5px;\"\r\n            >\r\n          </template>\r\n\r\n          <!-- 2. 如果没有图片但有视频，展示视频（图标或封面） -->\r\n          <template v-else-if=\"scope.row.videosList?.length > 0\">\r\n\r\n              <!-- 方式1：显示视频封面（如果有） -->\r\n              <video\r\n                  :src=\"scope.row.videosList[0]\"\r\n                  style=\"max-width: 50px; max-height: 100px;\"\r\n              ></video>\r\n\r\n          </template>\r\n\r\n          <!-- 3. 如果既没有图片也没有视频 -->\r\n          <span v-else>无内容</span>\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"content\" label=\"内容\"  :show-overflow-tooltip=\"true\"/>\r\n      <el-table-column prop=\"userId\" label=\"发布人ID\" width=\"100px\"/>\r\n      <el-table-column prop=\"username\" label=\"发布人名称\" width=\"100px\"/>\r\n      <el-table-column prop=\"createTime\" label=\"发布时间\" width=\"100px\" sortable/>\r\n      <el-table-column align=\"right\" label=\"操作\" width=\"200px\" fixed=\"right\">\r\n        <template slot=\"header\" slot-scope=\"scope\">\r\n          <el-input v-model=\"search\" size=\"mini\" placeholder=\"请输入内容关键字\">\r\n            <el-button slot=\"append\" icon=\"el-icon-search\"></el-button>\r\n          </el-input>\r\n        </template>\r\n        <template slot-scope=\"scope\">\r\n            <el-button type=\"danger\" icon=\"el-icon-chat\" plain @click=\"del(scope.row.id)\">删除\r\n            </el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </el-container>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  data() {\r\n    return {\r\n      search: '',\r\n      tradingData: [],\r\n      replyFeedback:{},\r\n      cellStyle: {\r\n        'text-align': 'center'\r\n      },\r\n      dialogFormVisible: false\r\n    }\r\n  },\r\n  created: function () {\r\n    this.getFeedbacks()\r\n  },\r\n  methods: {\r\n    filterTag(value, row) {\r\n      return row.type === value;\r\n    },\r\n    getFeedbacks() {\r\n      this.$axios.post('http://localhost:8080/trading/getTrading').then(resp => {\r\n        this.tradingData = resp.data.data\r\n      })\r\n    },del(id){\r\n      this.$confirm('此操作将永久删除, 是否继续?', '提示', {\r\n        confirmButtonText: '确定',\r\n        cancelButtonText: '取消',\r\n        type: 'warning'\r\n      }).then(() => {\r\n        this.$axios.delete('http://localhost:8080/trading/delete/' + id).then(resp => {\r\n          if (resp.data.code == 200) {\r\n            this.$message({\r\n              type: 'success',\r\n              message: '删除成功!'\r\n            });\r\n             this.getFeedbacks();\r\n          }\r\n        })\r\n\r\n      }).catch(() => {\r\n        this.$message({\r\n          type: 'info',\r\n          message: '已取消删除'\r\n        });\r\n      });\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style>\r\n</style>\r\n"],"mappings":"AA4DA;EACAA,KAAA;IACA;MACAC,MAAA;MACAC,WAAA;MACAC,aAAA;MACAC,SAAA;QACA;MACA;MACAC,iBAAA;IACA;EACA;EACAC,OAAA,WAAAA,CAAA;IACA,KAAAC,YAAA;EACA;EACAC,OAAA;IACAC,UAAAC,KAAA,EAAAC,GAAA;MACA,OAAAA,GAAA,CAAAC,IAAA,KAAAF,KAAA;IACA;IACAH,aAAA;MACA,KAAAM,MAAA,CAAAC,IAAA,6CAAAC,IAAA,CAAAC,IAAA;QACA,KAAAd,WAAA,GAAAc,IAAA,CAAAhB,IAAA,CAAAA,IAAA;MACA;IACA;IAAAiB,IAAAC,EAAA;MACA,KAAAC,QAAA;QACAC,iBAAA;QACAC,gBAAA;QACAT,IAAA;MACA,GAAAG,IAAA;QACA,KAAAF,MAAA,CAAAS,MAAA,2CAAAJ,EAAA,EAAAH,IAAA,CAAAC,IAAA;UACA,IAAAA,IAAA,CAAAhB,IAAA,CAAAuB,IAAA;YACA,KAAAC,QAAA;cACAZ,IAAA;cACAa,OAAA;YACA;YACA,KAAAlB,YAAA;UACA;QACA;MAEA,GAAAmB,KAAA;QACA,KAAAF,QAAA;UACAZ,IAAA;UACAa,OAAA;QACA;MACA;IACA;EACA;AACA","ignoreList":[]}]}