{"remainingRequest":"D:\\workspace\\blog\\vue\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\workspace\\blog\\vue\\src\\views\\userInterface\\MyCollect.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\workspace\\blog\\vue\\src\\views\\userInterface\\MyCollect.vue","mtime":1745758051000},{"path":"D:\\workspace\\blog\\vue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1746023425935},{"path":"D:\\workspace\\blog\\vue\\node_modules\\babel-loader\\lib\\index.js","mtime":1746023427203},{"path":"D:\\workspace\\blog\\vue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1746023425935},{"path":"D:\\workspace\\blog\\vue\\node_modules\\vue-loader\\lib\\index.js","mtime":1746023427772}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["MyCollect.vue"],"names":[],"mappings":";AA+CA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"MyCollect.vue","sourceRoot":"src/views/userInterface","sourcesContent":["<template>\r\n  <el-container class=\"ai-admin-container\">\r\n    <el-main class=\"ai-admin-main\">\r\n      <div class=\"ai-table-container\">\r\n        <el-table\r\n            :data=\"tradingData.filter(data => !search || data.title.toLowerCase().includes(search.toLowerCase()))\"\r\n            height=\"100%\"\r\n            :default-sort=\"{prop: 'createTime', order: 'descending'}\"\r\n            :header-cell-style='headerCellStyle'\r\n            :cell-style='cellStyle'\r\n            class=\"ai-data-table\"\r\n        >\r\n          <el-table-column prop=\"id\" label=\"ID\" width=\"80\" />\r\n          <el-table-column prop=\"blogId\" label=\"文章ID\"  />\r\n          <el-table-column prop=\"title\" label=\"标题\" />\r\n          <el-table-column prop=\"userId\" label=\"用户ID\"  />\r\n          <el-table-column prop=\"username\" label=\"用户名\"  />\r\n\r\n          <el-table-column align=\"right\" label=\"操作\" width=\"220\" fixed=\"right\">\r\n            <template slot=\"header\" slot-scope=\"scope\">\r\n              <el-input\r\n                  v-model=\"search\"\r\n                  size=\"small\"\r\n                  placeholder=\"搜索内容\"\r\n                  class=\"ai-search-input\"\r\n              >\r\n              </el-input>\r\n            </template>\r\n            <template slot-scope=\"scope\">\r\n              <el-button\r\n                  type=\"danger\"\r\n                  icon=\"el-icon-chat\"\r\n                  size=\"small\"\r\n                  class=\"ai-action-btn\"\r\n                  @click=\"del(scope.row.id)\"\r\n              >\r\n                删除\r\n              </el-button>\r\n            </template>\r\n          </el-table-column>\r\n        </el-table>\r\n      </div>\r\n    </el-main>\r\n  </el-container>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  data() {\r\n    return {\r\n      fileList: [],\r\n      dialogFormVisible: false,\r\n      tradingForm: {\r\n        images: ''\r\n      },\r\n      search: '',\r\n      tradingData: [],\r\n      cellStyle: {\r\n        'text-align': 'center',\r\n        'padding': '8px 0'\r\n      },\r\n      headerCellStyle: {\r\n        'background-color': '#f5f7fa',\r\n        'color': '#409EFF',\r\n        'font-weight': '500',\r\n        'text-align': 'center'\r\n      }\r\n    }\r\n  },mounted() {\r\n    const elMain = document.querySelector('.el-main');\r\n    if (elMain) {\r\n      elMain.style.overflow = 'visible'; // 设置为 visible 或删除该样式\r\n    }\r\n  },\r\n  methods: {\r\n    cancel() {\r\n      this.fileList = []\r\n      this.dialogFormVisible = false\r\n    },\r\n    getRepairData() {\r\n      this.$axios.post('http://localhost:8080/operation/getCollectByUserId/' + this.$store.getters.getUserId).then(resp => {\r\n        this.tradingData = resp.data.data\r\n      })\r\n    },\r\n    edit(trading) {\r\n      this.tradingForm = trading;\r\n      this.dialogFormVisible = true\r\n    },\r\n    del(id) {\r\n      this.$confirm('此操作将永久删除, 是否继续?', '提示', {\r\n        confirmButtonText: '确定',\r\n        cancelButtonText: '取消',\r\n        type: 'warning',\r\n        customClass: 'ai-confirm-dialog'\r\n      }).then(() => {\r\n        this.$axios.delete('http://localhost:8080/operation/delete/' + id).then(resp => {\r\n          if (resp.data.code == 200) {\r\n            this.$message({\r\n              type: 'success',\r\n              message: '删除成功!'\r\n            });\r\n            this.getRepairData();\r\n          }\r\n        })\r\n      }).catch(() => {\r\n        this.$message({\r\n          type: 'info',\r\n          message: '已取消删除'\r\n        });\r\n      });\r\n    },\r\n    handleSearch() {\r\n      // Search functionality\r\n    }\r\n  },\r\n  created() {\r\n    this.getRepairData()\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.ai-admin-container {\r\n  min-height: 100vh;\r\n  background-color: #f5f7fa;\r\n}\r\n\r\n.ai-admin-main {\r\n  padding: 20px;\r\n  height: calc(100vh - 60px);\r\n}\r\n\r\n.ai-table-container {\r\n  background: white;\r\n  border-radius: 8px;\r\n  box-shadow: 0 2px 12px 0 rgba(0, 0, 0, 0.1);\r\n  padding: 15px;\r\n  height: calc(100% - 60px);\r\n}\r\n\r\n.ai-data-table {\r\n  width: 100%;\r\n  border-radius: 8px;\r\n}\r\n\r\n.ai-data-table::before {\r\n  display: none;\r\n}\r\n\r\n.ai-search-input >>> .el-input__inner {\r\n  border-radius: 20px;\r\n  border-color: #dcdfe6;\r\n  transition: all 0.3s;\r\n}\r\n\r\n.ai-search-input >>> .el-input__inner:focus {\r\n  border-color: #409EFF;\r\n  box-shadow: 0 0 0 2px rgba(64, 158, 255, 0.2);\r\n}\r\n\r\n.ai-action-btn {\r\n  padding: 7px 12px;\r\n  margin-left: 5px;\r\n}\r\n</style>\r\n\r\n<style>\r\n.ai-confirm-dialog {\r\n  border-radius: 8px !important;\r\n  border: 1px solid rgba(64, 158, 255, 0.2) !important;\r\n}\r\n\r\n.ai-confirm-dialog .el-message-box__header {\r\n  border-bottom: 1px solid #ebeef5;\r\n}\r\n\r\n.ai-confirm-dialog .el-message-box__title {\r\n  color: #409EFF;\r\n}\r\n\r\n.ai-confirm-dialog .el-message-box__content {\r\n  padding: 20px 20px;\r\n}\r\n</style>"]}]}