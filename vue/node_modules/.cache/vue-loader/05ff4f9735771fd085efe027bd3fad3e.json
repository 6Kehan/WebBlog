{"remainingRequest":"D:\\workspace\\blog\\vue\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\workspace\\blog\\vue\\src\\views\\manage\\Blog.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\workspace\\blog\\vue\\src\\views\\manage\\Blog.vue","mtime":1746078315839},{"path":"D:\\workspace\\blog\\vue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1746023425935},{"path":"D:\\workspace\\blog\\vue\\node_modules\\babel-loader\\lib\\index.js","mtime":1746023427203},{"path":"D:\\workspace\\blog\\vue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1746023425935},{"path":"D:\\workspace\\blog\\vue\\node_modules\\vue-loader\\lib\\index.js","mtime":1746023427772}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Blog.vue"],"names":[],"mappings":";AA4DA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Blog.vue","sourceRoot":"src/views/manage","sourcesContent":["<template>\r\n  <el-container>\r\n    <el-header style=\"background-color: whitesmoke\">\r\n\r\n    </el-header>\r\n    <el-table\r\n        :data=\"tradingData.filter(data => !search || data.content.toLowerCase().includes(search.toLowerCase()))\"\r\n        height=\"100%\"\r\n        :default-sort=\"{prop: 'createTime', order: 'descending'}\"\r\n        :header-cell-style='cellStyle'\r\n        :cell-style='cellStyle'>\r\n      <el-table-column prop=\"id\" label=\"ID\" width=\"80px\"/>\r\n      <el-table-column prop=\"title\" label=\"标题\" width=\"100px\"/>\r\n      <el-table-column label=\"图片/视频\" width=\"200px\">\r\n        <template slot-scope=\"scope\">\r\n          <!-- 1. 如果有图片，循环展示所有图片 -->\r\n          <template v-if=\"scope.row.imagesList?.length > 0\">\r\n            <img\r\n                v-for=\"(img, index) in scope.row.imagesList\"\r\n                :key=\"'img-' + index\"\r\n                :src=\"img\"\r\n                style=\"max-width: 50px; max-height: 100px; margin-right: 5px;\"\r\n            >\r\n          </template>\r\n\r\n          <!-- 2. 如果没有图片但有视频，展示视频（图标或封面） -->\r\n          <template v-else-if=\"scope.row.videosList?.length > 0\">\r\n\r\n              <!-- 方式1：显示视频封面（如果有） -->\r\n              <video\r\n                  :src=\"scope.row.videosList[0]\"\r\n                  style=\"max-width: 50px; max-height: 100px;\"\r\n              ></video>\r\n\r\n          </template>\r\n\r\n          <!-- 3. 如果既没有图片也没有视频 -->\r\n          <span v-else>无内容</span>\r\n        </template>\r\n      </el-table-column>\r\n      <el-table-column prop=\"content\" label=\"内容\"  :show-overflow-tooltip=\"true\"/>\r\n      <el-table-column prop=\"userId\" label=\"发布人ID\" width=\"100px\"/>\r\n      <el-table-column prop=\"username\" label=\"发布人名称\" width=\"100px\"/>\r\n      <el-table-column prop=\"createTime\" label=\"发布时间\" width=\"100px\" sortable/>\r\n      <el-table-column align=\"right\" label=\"操作\" width=\"200px\" fixed=\"right\">\r\n        <template slot=\"header\" slot-scope=\"scope\">\r\n          <el-input v-model=\"search\" size=\"mini\" placeholder=\"请输入内容关键字\">\r\n            <el-button slot=\"append\" icon=\"el-icon-search\"></el-button>\r\n          </el-input>\r\n        </template>\r\n        <template slot-scope=\"scope\">\r\n            <el-button type=\"danger\" icon=\"el-icon-chat\" plain @click=\"del(scope.row.id)\">删除\r\n            </el-button>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n  </el-container>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  data() {\r\n    return {\r\n      search: '',\r\n      tradingData: [],\r\n      replyFeedback:{},\r\n      cellStyle: {\r\n        'text-align': 'center'\r\n      },\r\n      dialogFormVisible: false\r\n    }\r\n  },\r\n  created: function () {\r\n    this.getFeedbacks()\r\n  },\r\n  methods: {\r\n    filterTag(value, row) {\r\n      return row.type === value;\r\n    },\r\n    getFeedbacks() {\r\n      this.$axios.post('http://localhost:8080/trading/getTrading').then(resp => {\r\n        this.tradingData = resp.data.data\r\n      })\r\n    },del(id){\r\n      this.$confirm('此操作将永久删除, 是否继续?', '提示', {\r\n        confirmButtonText: '确定',\r\n        cancelButtonText: '取消',\r\n        type: 'warning'\r\n      }).then(() => {\r\n        this.$axios.delete('http://localhost:8080/trading/delete/' + id).then(resp => {\r\n          if (resp.data.code == 200) {\r\n            this.$message({\r\n              type: 'success',\r\n              message: '删除成功!'\r\n            });\r\n             this.getFeedbacks();\r\n          }\r\n        })\r\n\r\n      }).catch(() => {\r\n        this.$message({\r\n          type: 'info',\r\n          message: '已取消删除'\r\n        });\r\n      });\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style>\r\n</style>\r\n"]}]}